---
import type { Locale } from '@lib/locale';
import { useT } from '@lib/i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useT(locale);
---

<footer>
	<span>HERMES AGENT</span>
	<span class="spacer"></span>
	<a href="https://github.com/Hubery23/hermes-guide" rel="noopener" target="_blank">{t('footer.github')} ↗</a>
	<span>{t('footer.rss')}</span>
</footer>

<style>
	footer {
		background: var(--ink);
		color: var(--ink-muted);
		padding: 24px 32px;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 2px;
		display: flex;
		align-items: center;
		gap: 20px;
		border-top: 1px solid var(--ink-soft);
		text-transform: uppercase;
	}
	.sep { color: var(--tang); }
	.spacer { flex: 1; }
	a { color: var(--ink-faint); text-decoration: none; }
	a:hover { color: var(--sand); }
</style>
