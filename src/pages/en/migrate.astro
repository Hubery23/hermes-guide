---
import MarketingLayout from '@layouts/MarketingLayout.astro';
import SectionHead from '@components/SectionHead.astro';
import CompatChart from '@components/CompatChart.astro';
import MarqueeDivider from '@components/MarqueeDivider.astro';
import { compatPairs } from '@lib/data';
import { useT } from '@lib/i18n';
import { breadcrumbSchema } from '@lib/schemas';

const locale = 'en' as const;
const t = useT(locale);
const schema = breadcrumbSchema([
	{ name: 'Hermes Agent Guide', path: '/en/' },
	{ name: 'Migrate', path: '/en/migrate/' },
]);
---

<MarketingLayout
	locale={locale}
	title={t('meta.migrate.title')}
	description={t('meta.migrate.description')}
	ogImage="/og/migrate.png"
	schema={schema}
>
	<section class="intro">
		<div class="intro-inner">
			<div class="big">H/01.08</div>
			<h1>Leaving OpenClaw,<br />moving to Hermes Agent</h1>
			<p class="sub">Both tools share DNA — concepts map 1:1. Below is the author's tested crosswalk.</p>
			<a href="/en/7-days/day-01/" class="btn btn-primary">◉ No Hermes yet? Start at Day 01</a>
		</div>
	</section>

	<MarqueeDivider />

	<section class="sheet">
		<SectionHead num="A.02" title="Compatibility Sheet" en="兼容性对照表" />
		<CompatChart pairs={compatPairs} fromLabel="[ FROM ]" toLabel="[ TO · HERMES ]" fromTitle="OpenClaw" toTitle="Hermes Agent" />
	</section>

	<section class="steps">
		<SectionHead num="A.03" title="Full Walkthrough" en="STEP-BY-STEP" />
		<div class="steps-inner">
			<p class="lede">One <code>hermes claw migrate</code> moves SOUL.md, skills, configs, API keys and platform tokens. The full guide covers concept mapping, manual-rebuild checklist and common pitfalls.</p>
			<a href="/en/migrate/from-openclaw/" class="btn btn-primary">◉ Read the full migration guide</a>
		</div>
	</section>
</MarketingLayout>

<style>
	.intro { padding: 80px 32px; background: var(--sand); border-bottom: 1px solid var(--ink); }
	.intro-inner { max-width: 720px; }
	.big {
		font-family: var(--font-display);
		font-size: 120px;
		font-weight: 800;
		color: var(--tang);
		line-height: 0.85;
		letter-spacing: -5px;
		margin-bottom: 18px;
	}
	h1 {
		font-family: var(--font-display);
		font-size: 54px;
		font-weight: 700;
		letter-spacing: -1.5px;
		line-height: 1.05;
		margin: 0 0 18px;
	}
	.sub {
		font-family: var(--font-display);
		font-size: 20px;
		line-height: 1.35;
		max-width: 560px;
		margin-bottom: 28px;
	}
	.sheet, .steps { padding: 80px 32px; border-bottom: 1px solid var(--ink); }
	.steps { background: var(--paper); }
	.steps-inner { max-width: 720px; }
	.steps .lede {
		font-family: var(--font-display);
		font-size: 20px;
		line-height: 1.45;
		color: var(--ink);
		margin: 0 0 28px;
	}
	.steps .lede code {
		font-family: var(--font-mono);
		font-size: 15px;
		background: var(--sand);
		padding: 2px 8px;
		border: 1px solid var(--ink);
	}
	@media (max-width: 760px) {
		.big { font-size: 72px; }
		h1 { font-size: 32px; }
	}
</style>
