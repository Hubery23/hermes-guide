---
import MarketingLayout from '@layouts/MarketingLayout.astro';
import SectionHead from '@components/SectionHead.astro';
import DayCard from '@components/DayCard.astro';
import MarqueeDivider from '@components/MarqueeDivider.astro';
import { useT } from '@lib/i18n';
import { courseSchema } from '@lib/schemas';

const locale = 'en' as const;
const t = useT(locale);
const days = [
	{ day: 'DAY 01', titleZh: '跑起来：Hermes 的第一次对话', titleEn: 'Boot Up', desc: 'Install and complete your first chat.', href: '/en/7-days/day-01/' },
	{ day: 'DAY 02', titleZh: '挑个大脑：模型选型与 API 接入', titleEn: 'Pick a Brain', desc: 'Configure LLM and keys.', href: '/en/7-days/day-02/' },
	{ day: 'DAY 03', titleZh: '入驻聊天室：Telegram / Discord / Slack', titleEn: 'Go Social', desc: 'Bot token + .env.', href: '/en/7-days/day-03/' },
	{ day: 'DAY 04', titleZh: '让 Agent 动手：内置工具实战', titleEn: 'Give It Hands', desc: 'Trigger ≥2 tools.', href: '/en/7-days/day-04/' },
	{ day: 'DAY 05', titleZh: '教它新本事：安装第一个 Skill', titleEn: 'Teach a Trick', desc: 'Install a skill and trigger it.', milestone: true, href: '/en/7-days/day-05/' },
	{ day: 'DAY 06', titleZh: '记忆与状态：会话、压缩、备份', titleEn: 'Memory & State', desc: 'Cross-session memory.', href: '/en/7-days/day-06/' },
	{ day: 'DAY 07', titleZh: '全自动化：定时任务与故障排查', titleEn: 'Full Auto', desc: 'Scheduling + diagnostics.', href: '/en/7-days/day-07/' },
	{ day: 'BONUS', titleZh: '从 OpenClaw 搬家：平滑迁移指南', titleEn: 'Leaving OpenClaw', desc: 'Crosswalk + tested steps.', href: '/en/migrate/' },
];
---

<MarketingLayout
	locale={locale}
	title={t('meta.7days.title')}
	description={t('meta.7days.description')}
	ogImage="/og/course.png"
	schema={courseSchema(locale)}
>
	<section class="intro">
		<div class="big">H/01</div>
		<h1>7-Day Assembly</h1>
		<p class="sub">One module per day, each under an hour. Every command is tested on the author's own machine (macOS / Linux / WSL).</p>
	</section>

	<MarqueeDivider />

	<section class="grid-section">
		<SectionHead num="INDEX" title="All Chapters" en="全部章节" desc="Click any card to begin." />
		<div class="day-grid">
			{days.map((d) => <DayCard {...d} />)}
		</div>
	</section>
</MarketingLayout>

<style>
	.intro { padding: 80px 32px; background: var(--sand); border-bottom: 1px solid var(--ink); }
	.big {
		font-family: var(--font-display);
		font-size: 120px;
		font-weight: 800;
		color: var(--tang);
		line-height: 0.85;
		letter-spacing: -5px;
		margin-bottom: 18px;
	}
	h1 {
		font-family: var(--font-display);
		font-size: 54px;
		font-weight: 700;
		letter-spacing: -1.5px;
		line-height: 1.05;
		margin: 0 0 18px;
	}
	.sub { font-family: var(--font-display); font-size: 20px; line-height: 1.35; max-width: 620px; }
	.grid-section { padding: 80px 32px; }
	.day-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1px;
		background: var(--ink);
		border: 1px solid var(--ink);
	}
	@media (max-width: 980px) { .day-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
